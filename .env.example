# ==============================================================================
# Database Configuration (Next.js Full-Stack v3.0.0)
# ==============================================================================

# PostgreSQL 数据库连接 URL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ai_translate"

# 示例: postgresql://blue_focus@localhost:5432/ai_translate

# ==============================================================================
# NextAuth.js Configuration
# ==============================================================================

# NextAuth Secret (生成: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ==============================================================================
# LLM API Keys (至少配置一个)
# ==============================================================================

# OpenAI
OPENAI_API_KEY="sk-xxx"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Anthropic (Claude)
ANTHROPIC_API_KEY="sk-ant-xxx"

# Moonshot
MOONSHOT_API_KEY="sk-xxx"

# SiliconFlow
SILICONFLOW_API_KEY="xxx"

# ==============================================================================
# Stripe Payment
# ==============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ==============================================================================
# Application Settings
# ==============================================================================

NODE_ENV="development"
PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# 文件存储
UPLOAD_DIR="./uploads"
OUTPUT_DIR="./output"
MAX_FILE_SIZE_MB=100

# 支持的文件类型
SUPPORTED_FILE_TYPES="pptx,docx,xlsx,pdf"

# ==============================================================================
# Feature Flags
# ==============================================================================

ENABLE_REGISTRATION=true
ENABLE_PDF_TRANSLATION=false

# ==============================================================================
# Security
# ==============================================================================

JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN=86400
BCRYPT_ROUNDS=12
